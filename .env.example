# ── Required ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgresql://user:password@host:5432/onboarding

# ── AI Model ─────────────────────────────────────────────────
# CLAUDE_MODEL=claude-sonnet-4-6

# ── CRM Adapter ──────────────────────────────────────────────
# Which CRM to use. Options: hubspot, salesforce, pipedrive, zoho, airtable, webhook-only
# Or create your own: copy src/crm/adapters/_template.js → your-crm.js
CRM_ADAPTER=webhook-only

# HubSpot
# HUBSPOT_API_KEY=your-hubspot-private-app-token
# HUBSPOT_API_URL=https://api.hubapi.com

# Salesforce
# SALESFORCE_INSTANCE_URL=https://yourorg.my.salesforce.com
# SALESFORCE_ACCESS_TOKEN=your-oauth-token
# SALESFORCE_API_VERSION=v59.0

# Pipedrive
# PIPEDRIVE_API_TOKEN=your-api-token
# PIPEDRIVE_DOMAIN=yourcompany
# PIPEDRIVE_STAGE_ID=1

# Zoho
# ZOHO_ACCESS_TOKEN=your-oauth-token
# ZOHO_API_DOMAIN=https://www.zohoapis.com

# Airtable
# AIRTABLE_API_KEY=pat_...
# AIRTABLE_BASE_ID=appXXXXXXXXXX
# AIRTABLE_TABLE=Leads

# ── Email Adapter ───────────────────────────────────────────
# Which email provider to use. Options: resend, sendgrid, mailgun, smtp
# Or create your own: copy src/notifications/adapters/_template.js → your-provider.js
EMAIL_ADAPTER=resend

# Resend (default)
# RESEND_API_KEY=re_...

# SendGrid
# SENDGRID_API_KEY=SG.xxx

# Mailgun
# MAILGUN_API_KEY=key-xxx
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_REGION=us                    # "us" or "eu"

# SMTP (Gmail, Outlook, any SMTP server)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# SMTP_SECURE=false                    # true for port 465

# ── Notifications ────────────────────────────────────────────
NOTIFICATION_EMAIL=team@yourcompany.com
NOTIFICATION_FROM_EMAIL=agent@yourdomain.com

# Slack (preferred — paste an Incoming Webhook URL)
# SLACK_NOTIFICATION_WEBHOOK=https://hooks.slack.com/services/T.../B.../xxx

# ── Integrations ─────────────────────────────────────────────
# DOWNSTREAM_WEBHOOK_URL=https://your-next-agent.railway.app/webhook/lead

# ── Security ─────────────────────────────────────────────────
WEBHOOK_SECRET=generate-a-random-secret-here
ALLOWED_ORIGINS=https://yourclient.com,https://onboarding.yourclient.com

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_CHAT=30
RATE_LIMIT_GLOBAL=100
MAX_CONVERSATION_TURNS=50

# ── Database ─────────────────────────────────────────────────
# DB_POOL_MAX=10
# SESSION_TTL_DAYS=30

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
