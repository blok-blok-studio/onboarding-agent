# ── Required ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgresql://user:password@host:5432/onboarding

# ── CRM (choose one) ──────────────────────────────────────────
HUBSPOT_API_KEY=your-hubspot-private-app-token
# SALESFORCE_TOKEN=...

# ── Notifications ─────────────────────────────────────────────
NOTIFICATION_EMAIL=chase@blokblokstudio.com

# ── Integrations ──────────────────────────────────────────────
DOWNSTREAM_WEBHOOK_URL=https://your-next-agent.railway.app/webhook/lead

# ── Security ─────────────────────────────────────────────────
WEBHOOK_SECRET=generate-a-random-secret-here
ALLOWED_ORIGINS=https://yourclient.com,https://onboarding.yourclient.com

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_CHAT=30
RATE_LIMIT_GLOBAL=100
MAX_CONVERSATION_TURNS=50

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
