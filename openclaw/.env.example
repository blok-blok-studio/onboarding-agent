# ── OpenClaw Environment ──────────────────────────────────────
# Copy this to ~/.openclaw/.env or openclaw/.env

# ── Required ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgresql://user:password@host:5432/onboarding

# ── CRM ──────────────────────────────────────────────────────
HUBSPOT_API_KEY=your-hubspot-private-app-token

# ── Notifications ────────────────────────────────────────────
NOTIFICATION_EMAIL=chase@blokblokstudio.com

# ── Integrations ─────────────────────────────────────────────
DOWNSTREAM_WEBHOOK_URL=https://your-next-agent.railway.app/webhook/lead
WEBHOOK_SECRET=generate-a-random-secret-here

# ── Channel Tokens (uncomment as needed) ─────────────────────
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# DISCORD_BOT_TOKEN=your-discord-bot-token
# DISCORD_APP_ID=your-discord-app-id
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token
# SLACK_SIGNING_SECRET=your-slack-signing-secret

# ── Web Search (optional) ───────────────────────────────────
# BRAVE_API_KEY=your-brave-search-key
